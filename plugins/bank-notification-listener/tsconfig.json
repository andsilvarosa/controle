{
  "compilerOptions": {
    "module": "es2015",
    "moduleResolution": "node",
    "target": "es2017",
    "declaration": true,
    "declarationDir": "dist/esm",
    "sourceMap": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist/esm",
    "lib": ["dom", "es2015"]
  },
  "include": ["src/"]
}
